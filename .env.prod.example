# ===== Producción de Publi.lat — copiá a .env y completá =====
# Lo lee docker-compose.prod.yml. NO commitear el .env real.

# Secreto JWT: OBLIGATORIO, propio y largo (>=24 chars). Generá uno con:
#   openssl rand -hex 32
JWT_SECRET=

# Dominio que sirve la app (Caddy saca el certificado HTTPS para este dominio).
APP_DOMAIN=app.tudominio.com
# URLs públicas. Con Caddy + un solo dominio, las tres apuntan al mismo https://APP_DOMAIN.
APP_BASE_URL=https://app.tudominio.com
PANEL_BASE_URL=https://app.tudominio.com

# Postgres
POSTGRES_PASSWORD=poné-una-clave-fuerte

# Meta / Conversions API (sin esto el loop no matchea)
META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=
META_EVENT_SOURCE_URL=https://tudominio.com

# Evolution / WhatsApp
EVOLUTION_API_KEY=cambia-esta-clave
# Token para asegurar el webhook entrante de Evolution (recomendado).
EVOLUTION_WEBHOOK_TOKEN=
# URL pública con la que Evolution arma sus links (si exponés :8080).
EVOLUTION_SERVER_URL=https://wa.tudominio.com
# Versión de WhatsApp Web (actualizar si el QR deja de aparecer / error 405).
CONFIG_SESSION_PHONE_VERSION=2.3000.1035194821

# Pagos (cada uno opcional) — precio en USD por día (Stripe y USDT)
PRICE_PER_DAY_USD=1
# MercadoPago (LATAM)
MP_ACCESS_TOKEN=
MP_CURRENCY=ARS
MP_PRICE_PER_DAY=1000
# Stripe (tarjeta, global)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# USDT (cripto, global) vía NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# Landings en S3+CloudFront (opcional) — requiere: cd backend && npm i @aws-sdk/client-s3
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFRONT_DOMAIN=
