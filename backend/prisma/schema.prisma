// Publi.lat — esquema de datos
// El modelo cubre el loop de atribución completo + líneas, tokens y landings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  slug      String   @unique          // identifica al usuario en /go?u=<slug>
  password  String
  name      String?
  phone     String?                    // WhatsApp del usuario (registro)
  paymentDetection String @default("off") // off | assisted | auto (detección de pago en chat)
  // --- Panel maestro (super-admin) ---
  role          Role      @default(USER)
  suspended     Boolean   @default(false)
  isDemo        Boolean   @default(false)
  demoExpiresAt DateTime?
  source        String?                    // cómo llegó la cuenta (demo, referido, etc.)
  lastLoginAt   DateTime?
  // --- Límites de plan (configurables por cliente desde el panel) ---
  maxLines      Int       @default(1)        // líneas de WhatsApp permitidas
  maxLandings   Int       @default(50)       // landings permitidas
  tokenVersion  Int       @default(0)        // revocación de sesiones: al subir, invalida los JWT viejos
  // --- Landings aisladas en S3+CloudFront (anti-quemado, modelo ScaleOS) ---
  // Cada cliente tiene su PROPIA distribución CloudFront (dominio descartable): si Meta
  // quema una landing, cae solo ese dominio, no publi.lat ni los otros clientes.
  s3Prefix        String?   // carpeta del cliente en el bucket (default = slug)
  cloudfrontDomain String?  // dominio de la distribución del cliente (ej d50ti8s.cloudfront.net)
  cloudfrontDistId String?  // id de la distribución (para invalidar / reprovisionar)
  // --- Chat App (canal jugador↔cajero, módulo aislado): marca white-label por cuenta ---
  brandName       String?
  logoUrl         String?
  primaryColor    String?
  accentColor     String?
  welcomeText     String?   // texto de bienvenida en la PWA
  welcomeMsgText  String?   // primer mensaje automático de la conversación
  welcomeMsgImage String?
  // Popup/promo que ve el jugador al entrar a la PWA (imagen + texto + link). popupUpdatedAt
  // versiona el aviso: el jugador lo ve de nuevo cada vez que cambia (dedupe en el cliente).
  popupActive     Boolean   @default(false)
  popupImageUrl   String?
  popupTitle      String?
  popupText       String?
  popupLink       String?
  popupUpdatedAt  DateTime?
  createdAt DateTime @default(now())

  lines       WaLine[]
  contacts    Contact[]
  landings    Landing[]
  pixels      Pixel[]
  events      MetaEvent[]
  credit      Credit?
  integration Integration?
  payments    Payment[]
  supportMessages SupportMessage[]
  quickReplies QuickReply[]
  notifications Notification[]
  flows       Flow[]
  // Chat App (módulo aislado)
  chatPlayers       ChatPlayer[]
  chatConversations ChatConversation[]
  chatMessages      ChatMessage[]
  inviteCodes       InviteCode[]
  chatPushSubs      ChatPushSub[]
  brandingAssets    BrandingAsset[]
}

// Automatización / secuencia (tipo ManyChat) para WhatsApp.
model Flow {
  id        String   @id @default(cuid())
  userId    String
  name      String
  enabled   Boolean  @default(false)
  trigger   String   @default("first_message") // first_message | keyword
  keyword   String?                            // si trigger = keyword
  steps     Json     // [{ id, type: "message"|"delay"|"wait_reply", text?, minutes? }]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs      FlowRun[]

  @@index([userId])
}

// Link rastreado de una automatización: uno por (paso, contacto). Mide quién clickeó
// (estilo CTR de ManyChat). El código es el id (cuid) y se sirve en GET /r/:code.
model TrackedLink {
  id          String    @id @default(cuid())
  userId      String
  flowId      String?
  stepId      String?
  contactId   String?
  url         String
  label       String?
  clicks      Int       @default(0)
  lastClickAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([flowId, stepId])
}

// Estado de ejecución de una secuencia por contacto.
model FlowRun {
  id        String   @id @default(cuid())
  flowId    String
  contactId String
  stepIndex Int      @default(0)          // legacy (flujos lineales viejos)
  cursor    String   @default("0")        // posición en el árbol: "2" o "2:1:0" (paso:opción:subpaso)
  status    String   @default("running")  // running | waiting | waiting_option | done
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, status])
}

// Idempotencia de eventos entrantes de WhatsApp: el motor (sobre todo WAHA con
// message.any) puede entregar el MISMO mensaje dos veces casi simultáneas. Insertar
// aquí es atómico (key @unique): solo el primer evento procesa; el duplicado choca y
// se saltea, antes de crear contactos/mensajes. Evita leads duplicados por la carrera.
model InboundDedup {
  id        String   @id @default(cuid())
  key       String   @unique // "<instance>:<waMessageId>"
  createdAt DateTime @default(now())

  @@index([createdAt]) // para poder podar los viejos
}

// Notificaciones del usuario (nuevo lead, venta, línea caída, etc.).
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // lead | purchase | line_down | line_quality | system
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// Respuestas rápidas / mensajes guardados del Inbox (por usuario).
model QuickReply {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Hilo de soporte 1-a-1 entre cada cliente y el dueño (admin).
model SupportMessage {
  id        String   @id @default(cuid())
  userId    String
  fromAdmin Boolean  @default(false)
  body      String
  mediaUrl  String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// Auditoría de acciones del admin (dar días, demo, suspender, responder soporte).
model AdminLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetUserId String?
  meta         Json?
  createdAt    DateTime @default(now())
}

// Pixel de Meta + token CAPI. Una entrada por evento (Lead / Purchase), como ScaleOS.
model Pixel {
  id          String   @id @default(cuid())
  userId      String
  pixelId     String
  capiToken   String
  eventType   String   // "Lead" | "Purchase"
  siteUrl     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

// Línea de WhatsApp (sesión Baileys/Evolution).
model WaLine {
  id          String    @id @default(cuid())
  userId      String
  phone       String    // ej: 5492944684573
  label       String?
  status      String    @default("inactive") // inactive | active | paused
  provider    String    @default("baileys")  // baileys (QR/Evolution) | cloud (WhatsApp Cloud API oficial)
  sessionId   String?   // id de sesión Baileys/Evolution
  connected   Boolean   @default(false)
  // --- Cloud API oficial (para anuncios Click-to-WhatsApp / CTWA) ---
  wabaPhoneNumberId String?  // Phone Number ID de la Cloud API
  wabaId      String?        // WhatsApp Business Account ID
  accessToken String?        // token de la Cloud API (cifrado en reposo)
  verifyToken String?        // token de verificación del webhook de Meta
  registerPin String?        // PIN de registro de la Cloud API (cifrado en reposo)
  registered  Boolean   @default(false) // true si el número quedó registrado en la Cloud API
  qualityRating String?      // Cloud API: GREEN | YELLOW | RED (calidad del número)
  lastCheckedAt DateTime?    // último chequeo de salud de la línea
  // --- Anti-ban (líneas Baileys) ---
  proxyUrl        String?    // proxy de salida por línea (URL completa, cifrada en reposo)
  warmupEnabled   Boolean   @default(true)  // rampa de calentamiento activable por línea
  warmupStartedAt DateTime?  // arranca al primer emparejamiento; se resetea si cambia el número
  expiresAt   DateTime? // se desactiva al vencer (consumo de días)
  lastUsedAt  DateTime? // para rotación LRU de clics entre líneas activas
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  contacts    Contact[]
  messages    Message[]

  @@index([sessionId]) // lookup por instancia en cada evento del webhook
  @@index([userId])
}

// Crédito prepago: "días disponibles" (1 día = 1 línea activa 24h).
model Credit {
  id        String   @id @default(cuid())
  userId    String   @unique
  days      Int      @default(0)
  user      User     @relation(fields: [userId], references: [id])
  ledger    CreditLedger[]
}

model CreditLedger {
  id        String   @id @default(cuid())
  creditId  String
  delta     Int      // +compra / -consumo
  reason    String
  createdAt DateTime @default(now())
  credit    Credit   @relation(fields: [creditId], references: [id])
}

// Contacto/lead con TODA la atribución. external_id es la clave del match con Meta.
model Contact {
  id          String   @id @default(cuid())
  userId      String
  externalId  String   @unique          // se envía a Meta (hasheado) para el match
  phone       String?
  waJid       String?                   // JID crudo de WhatsApp (soporta @lid) para responder
  name        String?
  source      String?                   // fb | ig | an | ...
  campaignId  String?                   // id de campaña de Meta
  adId        String?
  pixelId     String?
  fbp         String?                   // cookie _fbp
  fbc         String?                   // cookie _fbc (derivada de fbclid)
  fbclid      String?
  ctwaClid    String?                    // click id de anuncios Click-to-WhatsApp (referral de la Cloud API)
  code        String?  @unique          // código corto incrustado en el msg de WA
  landingUrl  String?
  lineId      String?
  stage       Stage    @default(NUEVO)
  amount      Int?                       // monto de la venta (en centavos o unidad menor)
  purchasedAt DateTime?
  paymentDetected     Boolean   @default(false) // detección de pago en chat (a confirmar)
  paymentDetectedAmount Int?                     // monto detectado (centavos), si la IA lo leyó
  paymentDetectedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  line        WaLine?  @relation(fields: [lineId], references: [id])
  messages    Message[]
  flowRuns    FlowRun[]

  @@index([userId, phone])  // match del contacto en cada mensaje entrante
  @@index([userId, stage])  // kanban / listados por etapa
}

enum Stage {
  NUEVO
  CONTACTADO
  INTERESADO
  COMPRO
  PERDIDO
}

// Mensajes del Inbox.
model Message {
  id         String   @id @default(cuid())
  contactId  String
  lineId     String
  direction  String   // in | out
  body       String
  status     String   @default("sent") // salientes: sent | delivered | read | failed (ack de WhatsApp)
  error      String?  // motivo si WhatsApp rechazó el envío (ej: código 463)
  mediaType  String?  // mimetype si el mensaje trae imagen (ej image/jpeg)
  mediaData  String?  @db.Text // imagen en base64 (sin prefijo data:) para mostrar en el Inbox
  waMessageId String?  @unique // idempotencia: no procesar dos veces el mismo evento de WhatsApp
  createdAt  DateTime @default(now())
  contact    Contact  @relation(fields: [contactId], references: [id])
  line       WaLine   @relation(fields: [lineId], references: [id])

  @@index([contactId, createdAt])          // historial de conversación
  @@index([lineId, direction, createdAt])  // cupo de warmup + heatmap por línea
}

// Landing alojada (S3/CloudFront), una o varias por usuario.
model Landing {
  id         String   @id @default(cuid())
  userId     String
  name       String
  slug       String   @unique
  html       String   @db.Text
  config     Json?                       // campos del editor (headline, msg, etc.) para re-editar
  isPrimary  Boolean  @default(false)
  published  Boolean  @default(false)
  publishedUrl String?          // URL de campaña (CloudFront del cliente) o local /p/:slug
  publishedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

// Integración con CRM externo (Fase 5): dispara webhooks por evento.
model Integration {
  id         String   @id @default(cuid())
  userId     String   @unique
  mode       String   @default("nativo") // nativo | webhook | kommo
  webhookUrl String?
  secret     String?                     // para firmar el payload (HMAC) saliente
  inboundToken String? @unique           // token del webhook ENTRANTE (Kommo → Publi.lat: marca compra + Purchase)
  onLead     Boolean  @default(true)
  onPurchase Boolean  @default(true)
  enabled    Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

// Pago de días/tokens (Fase 5). Real con pasarela (MercadoPago) o stub en dev.
model Payment {
  id         String   @id @default(cuid())
  userId     String
  provider   String                      // mercadopago | stub
  externalId String?                     // id de preferencia/pago en la pasarela
  days       Int
  amount     Int?                        // centavos
  currency   String   @default("ARS")
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

// ============================================================================
// Chat App — canal jugador↔cajero (módulo AISLADO). No comparte tablas con el
// Inbox de WhatsApp (Contact/Message/WaLine). userId = cuenta dueña (el operador).
// ============================================================================

// Jugador (usuario final del chat), registrado passwordless por un link de invitación.
model ChatPlayer {
  id              String   @id @default(cuid())
  userId          String   // cuenta dueña
  nombre          String?
  casinoUsername  String   // usuario del jugador en el casino
  invitedByUserId String?  // operador que lo invitó (User.id)
  inviteCodeId    String?
  estatus         String   @default("active")
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations   ChatConversation[]
  pushSubs        ChatPushSub[]

  @@unique([userId, casinoUsername])
  @@index([userId])
}

// Conversación jugador↔cajero.
model ChatConversation {
  id                 String   @id @default(cuid())
  userId             String   // cuenta dueña
  playerId           String
  assignedOperatorId String?  // operador asignado (User.id)
  status             String   @default("open")
  unreadOperator     Int      @default(0)
  unreadPlayer       Int      @default(0)
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  player             ChatPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  messages           ChatMessage[]

  @@index([userId, status])
  @@index([playerId])
}

// Mensaje del chat (jugador / operador / sistema).
model ChatMessage {
  id             String   @id @default(cuid())
  userId         String   // cuenta dueña
  conversationId String
  senderType     String   // "player" | "operator" | "system"
  senderId       String?
  body           String?
  metadata       Json     @default("{}")
  readAt         DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Link de invitación single-use (un operador invita a un jugador).
model InviteCode {
  id         String   @id @default(cuid())
  userId     String   // cuenta dueña
  operatorId String   // operador que creó el link (User.id)
  code       String   @unique
  label      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, operatorId])
}

// Suscripción a Web Push de un jugador (para notificar mensajes con la PWA cerrada).
model ChatPushSub {
  id        String   @id @default(cuid())
  userId    String   // cuenta dueña
  playerId  String?
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  player    ChatPlayer? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([userId, endpoint])
  @@index([userId])
}

// Imágenes de branding del Chat App (logo, imagen de bienvenida) servidas por el PROPIO
// backend con URL corta y estable. Evita depender de un CDN público: el bucket S3 es privado
// y sin CloudFront la URL directa no carga. Para un logo por cuenta, bytea alcanza de sobra.
model BrandingAsset {
  id          String   @id @default(cuid())
  userId      String
  contentType String   // image/png | image/jpeg | image/webp | image/gif
  data        Bytes
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Log de eventos enviados a Meta (para auditoría y reintentos).
model MetaEvent {
  id         String   @id @default(cuid())
  userId     String
  contactId  String?
  eventName  String   // Lead | Purchase
  pixelId    String
  payload    Json
  status     String   @default("pending") // pending | sent | failed
  attempts   Int      @default(0)         // reintentos CAPI; tras el tope queda dead-letter
  response   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
