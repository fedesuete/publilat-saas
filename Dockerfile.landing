# Landing de marketing (publi.lat) — build estático + nginx.
FROM node:20-slim AS build
WORKDIR /app
COPY landing-web/package*.json ./
RUN npm install
COPY landing-web/ ./
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY deploy/nginx-landing.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
