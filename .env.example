# ===== App =====
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
PANEL_BASE_URL=http://localhost:5173
JWT_SECRET=cambia-esto-por-un-secreto-largo
# Cifra los tokens de CAPI por usuario (Mi Pixel). Generá uno: openssl rand -hex 32
# IMPORTANTE: si se pierde, los tokens guardados no se pueden descifrar.
APP_ENCRYPTION_KEY=

# ===== Base de datos =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/publilat?schema=public

# ===== Redis (colas/jobs, desde Fase 4) =====
REDIS_URL=redis://localhost:6379

# ===== Meta / Conversions API =====
META_PIXEL_ID=
META_CAPI_TOKEN=
# Dominio donde está la landing (debe coincidir con el del pixel)
META_EVENT_SOURCE_URL=https://tudominio.com
# Código de prueba del Test Events Tool (vacío en producción)
META_TEST_EVENT_CODE=

# ===== WhatsApp (Fase 2) =====
# Opción Evolution API (recomendada)
EVOLUTION_API_URL=http://localhost:8080
# Debe coincidir con AUTHENTICATION_API_KEY del docker-compose.yml
EVOLUTION_API_KEY=publilat-dev-key-cambiame
# URL a la que Evolution (en Docker) le pega para notificar eventos.
# Desde el contenedor, el host se alcanza con host.docker.internal.
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:4000/api/wa/webhook
# (alternativa Baileys directo no usa estas vars)

# ===== Landings (Fase 5) — opcional. Si falta, las landings se sirven desde /p/:slug =====
# Para publicar en S3+CloudFront: npm i @aws-sdk/client-s3 (en backend/) y completar:
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFRONT_DOMAIN=

# ===== Pagos (Fase 5) — cada proveedor es opcional. Sin claves -> checkout stub =====
# Precio en USD por día (lo usan Stripe y USDT).
PRICE_PER_DAY_USD=1

# MercadoPago (LATAM): token del vendedor (Bearer). MP_PRICE_PER_DAY en MP_CURRENCY.
MP_ACCESS_TOKEN=
MP_CURRENCY=ARS
MP_PRICE_PER_DAY=1000

# Stripe (tarjeta, global): clave secreta + secret del webhook (whsec_...).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# USDT (cripto, global) vía NOWPayments: API key + secret del IPN.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Red/moneda de cobro (ej: usdttrc20, usdterc20, usdtbsc).
NOWPAYMENTS_PAY_CURRENCY=usdttrc20
