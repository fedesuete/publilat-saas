# ===== App =====
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
PANEL_BASE_URL=http://localhost:5173
JWT_SECRET=cambia-esto-por-un-secreto-largo
# Cifra los tokens de CAPI por usuario (Mi Pixel). Generá uno: openssl rand -hex 32
# IMPORTANTE: si se pierde, los tokens guardados no se pueden descifrar.
APP_ENCRYPTION_KEY=

# ===== Base de datos =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/publilat?schema=public

# ===== Redis (colas/jobs, desde Fase 4) =====
REDIS_URL=redis://localhost:6379

# ===== Meta / Conversions API =====
META_PIXEL_ID=
META_CAPI_TOKEN=
# Dominio donde está la landing (debe coincidir con el del pixel)
META_EVENT_SOURCE_URL=https://tudominio.com
# Código de prueba del Test Events Tool (vacío en producción)
META_TEST_EVENT_CODE=

# ===== WhatsApp (Fase 2) =====
# Opción Evolution API (recomendada)
EVOLUTION_API_URL=http://localhost:8080
# Debe coincidir con AUTHENTICATION_API_KEY del docker-compose.yml
EVOLUTION_API_KEY=publilat-dev-key-cambiame
# URL a la que Evolution (en Docker) le pega para notificar eventos.
# Desde el contenedor, el host se alcanza con host.docker.internal.
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:4000/api/wa/webhook
# (alternativa Baileys directo no usa estas vars)
# Versión de WhatsApp Web que usa Baileys (la comparte el compose de Evolution y el
# backend, que la VIGILA con el job wa-version-check y avisa cuando hay que renovarla).
# EXPIRA ~cada 2 meses: sacar la vigente de
# https://raw.githubusercontent.com/wppconnect-team/wa-version/main/versions.json
# (campo currentVersion, SIN el sufijo -alpha).
CONFIG_SESSION_PHONE_VERSION=2.3000.1042991638
# Rampa de calentamiento para líneas Baileys nuevas: cupo de envíos por 24 h para el
# día 1..N de vida de la línea (anti-ban / anti-463). Vacío = 20,50,100,200,400.
WARMUP_DAILY_CAPS=

# ===== Chat App (canal jugador↔cajero, módulo aislado) =====
# Origen(es) de la PWA del jugador (separados por coma). Se permite por CORS SOLO en
# /api/chat/* y en el handshake del socket /chat. Ej: https://chat.publi.lat
CHAT_PWA_ORIGIN=
# Web Push (VAPID). Generar con: npx web-push generate-vapid-keys
# NO commitear claves reales; setear en el .env del VPS.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@publi.lat
# --- Build del frontend (NO son del backend; van al entorno de build de Vite) ---
# PWA del jugador (frontend-pwa): a qué API pega. Ej: https://app.publi.lat
VITE_API_URL=
# Panel (frontend): dominio de la PWA para armar los links de invitación /i/:code
VITE_CHAT_PWA_URL=https://chat.publi.lat

# ===== Motor de WhatsApp =====
# waha (WEBJS, motor actual en producción: Chromium real, manda el tctoken -> sin 463 en
# fríos) | evolution (motor anterior, queda de ROLLBACK: poner "evolution" acá y
# `docker compose -f docker-compose.vps.yml up -d app` — las sesiones no migran entre
# motores, al cambiar hay que re-escanear las líneas UNA vez).
WA_ENGINE=waha
# WAHA (docker-compose.waha.yml). Dashboard: <WAHA_BASE_URL>/dashboard
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=cambia-esta-clave
# Engine de las sesiones WAHA: WEBJS (Chromium real, más resistente al 463) | NOWEB (Baileys al día).
WAHA_ENGINE=WEBJS
# URL del webhook que WAHA le pega al backend. Si está vacía usa EVOLUTION_WEBHOOK_URL.
WAHA_WEBHOOK_URL=

# ===== Alertas por email (opcional; sin SMTP_HOST queda todo desactivado) =====
# Avisa por email cuando una línea se cae (al dueño y al admin) y cuando hay que
# renovar la versión de WhatsApp Web (al admin).
SMTP_HOST=
SMTP_PORT=587
# true = TLS directo (puerto 465); false/vacío = STARTTLS (587)
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Publi.lat <alertas@publi.lat>"
# Email del operador de la plataforma (recibe copia de líneas caídas y avisos de versión).
ADMIN_ALERT_EMAIL=

# ===== WhatsApp Cloud API oficial (anuncios Click-to-WhatsApp / CTWA) =====
# Versión de la Graph API para las líneas Cloud. Los tokens de cada cliente van por línea.
WHATSAPP_GRAPH_VERSION=v20.0
META_GRAPH_VERSION=v20.0

# ===== Embedded Signup (NUESTRA app como Tech Provider) — credenciales globales =====
# De la app de Meta (developers.facebook.com). El APP_SECRET es secreto, solo backend.
META_APP_ID=
META_APP_SECRET=
# config_id de la configuración de Embedded Signup.
META_ES_CONFIG_ID=
# Verify token del webhook de Cloud API a nivel app (lo pegás en Meta una sola vez).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ===== Detección de pago en el chat (texto + comprobante por imagen con IA) =====
# Modo por usuario en Configuración: off | assisted | auto. La lectura de comprobantes
# por imagen usa Claude (visión). Sin esta clave, la detección por TEXTO igual funciona.
# Elegí UNA de las dos formas (no las dos a la vez, la API las rechaza juntas):
#  A) Token de la suscripción de Claude (no cobra por token aparte). De corta duración:
#     hay que renovarlo. Se obtiene con `ant auth login` -> `ant auth print-credentials --access-token`.
ANTHROPIC_AUTH_TOKEN=
#  B) API key clásica (pago por token) de console.anthropic.com.
ANTHROPIC_API_KEY=
#  C) OpenAI (ChatGPT): si está, tiene prioridad. Modelo barato con visión.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
# Modelo de visión (económico para OCR de comprobantes). Por defecto Claude Haiku 4.5.
ANTHROPIC_VISION_MODEL=claude-haiku-4-5
# Moneda por defecto si la IA no la identifica (Paraguay -> PYG).
DEFAULT_CURRENCY=PYG
# Confianza mínima (0..1) para disparar el Purchase en modo automático.
PAYMENT_AUTO_MIN_CONFIDENCE=0.7
# Anti cost-DoS: máximo de análisis de comprobante por IA por contacto por hora.
RECEIPT_AI_MAX_PER_HOUR=20
# Tope de tamaño (bytes) para media entrante que se baja y guarda como base64. 15 MB.
MAX_MEDIA_BYTES=15728640

# ===== Landings aisladas en S3 + CloudFront (anti-quemado, modelo ScaleOS) =====
# Con esto, cada cliente tiene su PROPIA distribución CloudFront (dominio *.cloudfront.net
# descartable): si Meta quema una landing, cae solo ese dominio, no publi.lat ni los otros
# clientes. Se auto-provisiona al publicar. Si falta, las landings caen a /p/:slug (solo preview).
AWS_REGION=us-east-2
AWS_S3_BUCKET=publilat-landings
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# ID de la cuenta de AWS (12 dígitos): acota la bucket policy a TUS distribuciones CloudFront.
AWS_ACCOUNT_ID=
# (legado) dominio CloudFront global compartido — el modelo por-cliente NO lo usa.
CLOUDFRONT_DOMAIN=

# ===== Pagos (Fase 5) — cada proveedor es opcional. Sin claves -> checkout stub =====
# Precio en USD por día (lo usan Stripe y USDT).
PRICE_PER_DAY_USD=2
# Tarifa con descuento por día para packs grandes (>= 90 días).
PRICE_PER_DAY_USD_90=1.5

# USDT directo a tu wallet (red Tron / TRC20). Si lo cargás, el cliente paga a esta
# dirección y verificamos la transacción on-chain por el TXID (sin procesador externo).
USDT_TRC20_ADDRESS=
# Opcional: API key de TronGrid para más límite de consultas (trongrid.io).
TRONGRID_API_KEY=

# MercadoPago (LATAM): token del vendedor (Bearer). MP_PRICE_PER_DAY en MP_CURRENCY.
MP_ACCESS_TOKEN=
MP_CURRENCY=ARS
MP_PRICE_PER_DAY=1000

# Stripe (tarjeta, global): clave secreta + secret del webhook (whsec_...).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# USDT (cripto, global) vía NOWPayments: API key + secret del IPN.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Red/moneda de cobro (ej: usdttrc20, usdterc20, usdtbsc).
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# Pagopar (Paraguay: tarjetas locales/internacionales, billeteras, QR, PIX).
# Claves del panel del vendedor: pagopar.com -> "Integrar con mi sitio web".
# Configurar allá la URL de respuesta: https://<tu-app>/api/billing/webhook/pagopar
# PAGOPAR_PRICE_PER_DAY en guaraníes (PYG, entero; el pedido mínimo es Gs. 1.000).
PAGOPAR_PUBLIC_KEY=
PAGOPAR_PRIVATE_KEY=
PAGOPAR_PRICE_PER_DAY=7500
